{
  "name": "dfds-nextjs-starter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,css}\"",
    "prebuild": "tsc --noEmit",
    "check": "tsc --noEmit && prettier --check \"**/*.{ts,tsx,css}\""
  },
  "dependencies": {
    "@dfds-frontend/compass-ui": "^5.3.0",
    "@dfds-frontend/navigator-components": "^0.4.2",
    "@dfds-frontend/navigator-icons": "^1.3.1",
    "@dfds-frontend/navigator-styles": "^1.1.0",
    "@radix-ui/react-select": "^2.2.6",
    "@tanstack/react-query": "^5.90.21",
    "lucide-react": "^0.561.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.3",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^27.0.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.7.2",
    "vitest": "^3.0.5",
    "web-vitals": "^5.1.0"
  }
}
